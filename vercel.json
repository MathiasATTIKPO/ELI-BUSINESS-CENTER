{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/cashier",
      "destination": "/admin/index.html"
    },
    {
      "source": "/cashier/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/technician",
      "destination": "/admin/index.html"
    },
    {
      "source": "/technician/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/vip",
      "destination": "/admin/index.html"
    },
    {
      "source": "/vip/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/reseller",
      "destination": "/admin/index.html"
    },
    {
      "source": "/reseller/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
